import fitz
import pymupdf
import base64
from openai import OpenAI
doc = fitz.open("/Users/lookupthesky/Desktop/学习/AI算法学习/直播/第七周/Week07-信息抽取与GraphRAG.pdf")
page = doc[16]
text = page.get_text()
print(text)
model = "qwen3-vl-plus"
client = OpenAI(
    # 若没有配置环境变量，请用百炼API Key将下行替换为：api_key="sk-xxx",
