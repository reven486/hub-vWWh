# 数据库解析
from typing import Union
import traceback
from sqlalchemy import create_engine, inspect, func, select, Table, MetaData, text
import pandas as pd

class DBParser:
    """DBParser"""
    def __init__(self, db_url:str) -> None:
        """初始化
        db_url:数据库链接地址
        """
        if 'sqlite' in db_url:
            self.db_type = 'sqlite'
        elif 'mysql' in db_url:
            self.db_type = 'mysql'
        # 连接数据库
        self.engine = create_engine(db_url, echo=False)
        self.conn = self.engine.connect()
        self.db_url = db_url
        # 查看表明
        self.inspector = inspect(self.engine)
        self.table_names = self.inspector.get_table_names()

        self._table_fileds = {}  # 数据表字段
        self.foreign_keys = []  # 数据库外键
        self._table_sample = {}  # 数据表样例
        # 依次对每张表的字段进行统计
        for table_name in self.table_names:
            print("Table ->", table_name)
            self._table_fileds[table_name] = {}
            # 累计外键
            self.foreign_keys += [
                {
                    'constrained_table': table_name,
                    'constrained_columns': x['constrained_columns'],
                    'referred_tables': x['referred_table'],
                    'referred_columns': x['referred_columns']
                } for x in self.inspector.get_foreign_keys(table_name)
            ]
            # 获取当前表的字段信息
            table_instance = Table(table_name, MetaData(), autoload_with=self.engine)
            table_columns = self.inspector.get_columns(table_name)
            self._table_fileds[table_name] = {x['name']: x for x in table_columns}
            # 对当前字段进行统计
            for columns_meta in table_columns:
                # 获取当前字段
                columns_instance = getattr(table_instance.columns, columns_meta['name'])
                # 统计unique
                query = select(func.count(func.distinct(columns_instance)))
                distinct_count = self.conn.execute(query).fetchone()[0]
                self._table_fileds[table_name][columns_meta['name']]['distinct'] = distinct_count

                # 统计most frequency value
                field_type = self._table_fileds[table_name][columns_meta['name']]['type']
                field_type = str(field_type)
                if 'text' in field_type.lower() or 'char' in field_type.lower():
                    query = (
                        select(columns_instance, func.count().label('count')).group_by(columns_instance)
                        .order_by(func.count().desc()).limit(1)
                    )
                    top1_value = self.conn.execute(query).fetchone()[0]
                    self._table_fileds[table_name][columns_meta['name']]['mode'] = top1_value

                # 统计missing个数
                query = select(func.count()).filter(columns_instance == None)
                nan_count = self.conn.execute(query).fetchone()[0]
                self._table_fileds[table_name][columns_meta['name']]['nan_count'] = nan_count

                # 统计max
                query = select(func.max(columns_instance))
                max_value = self.conn.execute(query).fetchone()[0]
                self._table_fileds[table_name][columns_meta['name']]['max'] = max_value

                # 统计min
                query = select(func.min(columns_instance))
                min_value = self.conn.execute(query).fetchone()[0]
                self._table_fileds[table_name][columns_meta['name']]['min'] = min_value

                # 任意取值
                query = select(columns_instance).limit(10)
                random_value = self.conn.execute(query).all()
                random_value = [x[0] for x in random_value]
                random_value = [str(x) for x in random_value if x is not None]
                random_value = list(set(random_value))
                self._table_fileds[table_name][columns_meta['name']]['random'] = random_value[:3]

            # 获取表样例（第一行）
            query = select(table_instance)
            self._table_sample[table_name] = pd.DataFrame([self.conn.execute(query).fetchone()])
            self._table_sample[table_name].columns = [x['name'] for x in table_columns]

    def get_table_fields(self, table_name) -> pd.DataFrame:
        """获取表字段信息"""
        return pd.DataFrame.from_dict(self._table_fileds[table_name]).T

    def get_data_relations(self) -> pd.DataFrame:
        """获取数据库链接信息（主键和外键）"""
        return pd.DataFrame(self.foreign_keys)

    def get_table_sample(self, table_name) -> pd.DataFrame:
        """获取数据表样例"""
        return self._table_sample[table_name]
    def check_sql(self, sql) -> Union[bool, str]:
        """检查sql是否合理
        参数
            sql：待执行句子
        返回：是否可以运行 报错信息
        """
        try:
            self.conn.execute(sql)
            return True, 'ok'
        except:
            err_msg = traceback.format_exc()
            return False, err_msg

    def execute_sql(self, sql) -> bool:
        """运行sql"""
        result = self.conn.execute(sql)
        return  list(result)
